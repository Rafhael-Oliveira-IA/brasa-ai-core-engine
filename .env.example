APP_NAME=Brasa AI Core Lite
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Alibaba Model Studio (OpenAI-compatible)
ALIBABA_API_KEY=
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ALIBABA_MODEL_FLASH=qwen-turbo-latest
ALIBABA_MODEL_PLUS=qwen-plus-latest
ALIBABA_MODEL_MAX=qwen-max-latest

MAX_ESCALATION_DEPTH=3
REQUEST_BUDGET_USD=0.20

ENABLE_REFLECTION_SCHEDULER=false
REFLECTION_INTERVAL_MINUTES=1440

# Hierarchical Knowledge Compiler
KNOWLEDGE_MAX_FILE_BYTES=300000
KNOWLEDGE_INCLUDE_EXTENSIONS=.py,.md,.txt,.json,.yaml,.yml,.toml,.ini,.ts,.tsx,.js,.jsx,.cs,.java,.kt,.go,.rs,.cpp,.c,.h
